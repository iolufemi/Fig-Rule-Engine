  "overrides": {
    "minimatch": ">=10.2.1",
    "glob": ">=11.0.0"
  },
  "dependencies": {
    "axios": "^1.12.0",
    "json-rules-engine": "^7.3.1",
    "lodash": "^4.17.22",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "@types/chai": "^4.3.0",
    "@types/lodash": "^4.17.24",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "c8": "^10.1.2",
    "chai": "^5.0.0",
    "chai-as-promised": "^8.0.0",
    "eslint": "^10.0.1",
    "sinon": "^21.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "types": "dist/index.d.ts",
